# LLM Gateway Configuration
# Required: OpenAI-compatible/Anthropic-compatible gateway credentials
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=https://your-gateway-url

# Optional: model name (defaults to @Pages/hy3-preview)
AI_GATEWAY_MODEL=@Pages/hy3-preview

# Optional: small/fast model used by Claude Agent SDK subprocesses
AI_GATEWAY_SMALL_MODEL=@Pages/hy3-preview

